# Supabase — copia estos valores desde tu proyecto en supabase.com/dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc..."

# Solo backend (NUNCA expongas en cliente). Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."

# Sentry (opcional para arrancar)
# NEXT_PUBLIC_SENTRY_DSN=""

# URLs públicas (para callbacks de auth, redirects, etc.)
NEXT_PUBLIC_ADMIN_URL="http://localhost:3000"
NEXT_PUBLIC_STAFF_URL="http://localhost:3001"
NEXT_PUBLIC_CLIENTE_URL="http://localhost:3002"
