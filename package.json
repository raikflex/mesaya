{
  "name": "mesaya",
  "version": "0.0.1",
  "private": true,
  "description": "MesaYA — sistema web para restaurantes en Colombia",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=@mesaya/admin",
    "dev:staff": "turbo run dev --filter=@mesaya/staff",
    "dev:cliente": "turbo run dev --filter=@mesaya/cliente",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "db:types": "supabase gen types typescript --linked --schema public > packages/database/src/types.generated.ts && pnpm format",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "supabase": "^1.200.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
